{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NoSignal",
  "version": "0.1.0",
  "identifier": "io.github.shadowxcc.NoSignal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NoSignal",
        "width": 1000,
        "height": 660,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "linux": {
      "deb": {
        "files": {
          "/usr/lib/systemd/user/nosignal-daemon.service": "../../packaging/nosignal-daemon.service",
          "/usr/share/dbus-1/services/io.github.shadowxcc.NoSignal.Daemon1.service": "../../packaging/io.github.shadowxcc.NoSignal.Daemon1.service",
          "/usr/lib/udev/rules.d/99-nosignal-i2c.rules": "../../packaging/99-nosignal-i2c.rules"
        }
      },
      "rpm": {
        "files": {
          "/usr/lib/systemd/user/nosignal-daemon.service": "../../packaging/nosignal-daemon.service",
          "/usr/share/dbus-1/services/io.github.shadowxcc.NoSignal.Daemon1.service": "../../packaging/io.github.shadowxcc.NoSignal.Daemon1.service",
          "/usr/lib/udev/rules.d/99-nosignal-i2c.rules": "../../packaging/99-nosignal-i2c.rules"
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
