# DBus activation for the NoSignal daemon: any client calling the well-known
# name starts the daemon automatically.
# Installed by the .deb/.rpm to /usr/share/dbus-1/services/.
#

[D-BUS Service]
Name=io.github.shadowxcc.NoSignal.Daemon1
Exec=/usr/bin/nosignald
SystemdService=nosignal-daemon.service
